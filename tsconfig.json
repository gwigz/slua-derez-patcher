{
  "include": ["src/patcher"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["@typescript-to-lua/language-extensions", "@gwigz/slua-types"],
  },
  "tstl": {
    "extension": "slua",
    "luaTarget": "Luau",
    "luaLibImport": "inline",
    "luaPlugins": [{ "name": "@gwigz/slua-tstl-plugin" }],
  },
}
