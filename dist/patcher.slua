--[[
SLua Derez Patcher — bulk inventory updater for Second Life objects

Place this script inside a prim alongside the objects you want to patch.
Each object must contain a copy of the bootstrap script (bootstrap.slua).
Scripts and items in the prim's inventory are matched to objects by naming
convention, see inventory.ts for details.

On startup, an HTTP-in URL is requested and printed to owner chat. Open
it in a browser to access the web UI, or use chat commands on channel 7:
  /7 url       - print the HTTP-in URL
  /7 auto      - toggle auto-update on inventory changes
  /7 auto <n>  - enable auto-update with <n> second debounce

Patch protocol (COMM_CHANNEL):
  1. Patcher rezzes object with PIN as start param
  2. Bootstrap sets pin, sends "pinned"
  3. Patcher transfers items and scripts, sends "done"
  4. Bootstrap confirms with "ready"
  5. Patcher derezzes object back to inventory

@link https://github.com/gwigz/slua-derez-patcher
]]

--- Owner chat channel for commands (patcher only).
local CMD_CHANNEL = 7

--- Internal channel for patcher/bootstrap protocol messages.
local COMM_CHANNEL = -47123

--- Shared secret for `ll.RemoteLoadScriptPin` / `ll.SetRemoteScriptAccessPin`.
local PIN = 87654321

--[[ Generated with @gwigz/slua - https://github.com/gwigz/slua ]]

--- Matches an object name against a wildcard pattern.
--
-- Supported patterns:
--   `"*"`        Matches everything
--   `"prefix*"`  Matches names starting with prefix
--   `"*suffix"`  Matches names ending with suffix
--   `"exact"`    Matches the exact name (no wildcard)
local function wildcardMatches(objectName, pattern)
  if pattern == "*" then
    return true
  end

  local starIdx = (string.find(pattern, "*", 1, true) or 0) - 1

  if starIdx < 0 then
    return objectName == pattern
  end

  if starIdx == 0 then
    local suffix = string.sub(pattern, 2)

    return #objectName >= #suffix and string.sub(objectName, #objectName - #suffix + 1) == suffix
  end

  return string.find(objectName, string.sub(pattern, 1, starIdx), 1, true) == 1
end

--- Matches an object name against one or more comma-separated wildcard
-- patterns. Returns true if any pattern matches.
local function patternMatches(objectName, pattern)
  if string.find(pattern, ",", 1, true) ~= nil then
    for ____, part in ipairs(string.split(pattern, ",")) do
      if wildcardMatches(objectName, part) then
        return true
      end
    end

    return false
  end

  return wildcardMatches(objectName, pattern)
end

--- Checks whether an inventory item targets the given object.
--
-- Items use a naming convention with a `/` separator:
--   `"ObjectName/script"`    Exact match on object name
--   `"{pattern}/script"`     Wildcard or comma pattern match
--
-- Returns false for items without a `/` separator.
local function matchesObject(name, objectName)
  local slashIdx = (string.find(name, "/", 1, true) or 0) - 1

  if slashIdx < 0 then
    return false
  end

  local prefix = string.sub(name, 1, slashIdx)

  if prefix == objectName then
    return true
  end

  if string.find(prefix, "{", 1, true) == 1 and (string.find(prefix, "}", 1, true) or 0) - 1 == #prefix - 1 then
    return patternMatches(objectName, string.sub(prefix, 2, #prefix - 1))
  end

  return false
end

--- Returns the names of all object-type items in the prim's inventory.
local function getObjectNames()
  local names = {}
  local count = ll.GetInventoryNumber(INVENTORY_OBJECT)

  do
    local i = 0

    while i < count do
      names[#names + 1] = ll.GetInventoryName(INVENTORY_OBJECT, i + 1)
      i = i + 1
    end
  end

  return names
end

--- Collects all inventory items targeting the given object, separated into
-- scripts and non-script items. Excludes the patcher script itself and
-- any object-type inventory entries.
local function getItemsForObject(selfName, objectName)
  local scripts = {}
  local items = {}
  local count = ll.GetInventoryNumber(INVENTORY_ALL)

  do
    local i = 0

    while i < count do
      local name = ll.GetInventoryName(INVENTORY_ALL, i + 1)
      local itemType = ll.GetInventoryType(name)

      if name ~= selfName and itemType ~= INVENTORY_OBJECT then
        if matchesObject(name, objectName) then
          if itemType == INVENTORY_SCRIPT then
            scripts[#scripts + 1] = name
          else
            items[#items + 1] = name
          end
        end
      end

      i = i + 1
    end
  end

  return { scripts = scripts, items = items }
end

--- Strips the `ObjectName/` prefix, returning just the item's own name.
local function targetItemName(fullName)
  local idx = (string.find(fullName, "/", 1, true) or 0) - 1

  return if idx < 0 then fullName else string.sub(fullName, idx + 1 + 1)
end

--- Inventory type constant -> short human-readable label.
local TYPE_LABELS = {

  [INVENTORY_SCRIPT] = "script",
  [INVENTORY_TEXTURE] = "texture",
  [INVENTORY_SOUND] = "sound",
  [INVENTORY_LANDMARK] = "landmark",
  [INVENTORY_NOTECARD] = "notecard",
  [INVENTORY_ANIMATION] = "animation",
  [INVENTORY_GESTURE] = "gesture",
  [INVENTORY_CLOTHING] = "clothing",
  [INVENTORY_BODYPART] = "body part",
  [INVENTORY_SETTING] = "setting",
  [INVENTORY_MATERIAL] = "material",
}

--- Returns a short human-readable label for an inventory type constant.
local function inventoryTypeLabel(itemType)
  return TYPE_LABELS[itemType] or "item"
end

local takeSnapshot, diffSnapshot, getAffectedObjects, snapshot, selfName

function takeSnapshot()
  local snap = {}
  local count = ll.GetInventoryNumber(INVENTORY_ALL)

  do
    local i = 0

    while i < count do
      local name = ll.GetInventoryName(INVENTORY_ALL, i + 1)

      if name ~= selfName and (string.find(name, "/", 1, true) or 0) - 1 >= 0 then
        snap[name] = ll.GetInventoryKey(name)
      end

      i = i + 1
    end
  end

  return snap
end

function diffSnapshot()
  local changed = {}
  local newSnap = takeSnapshot()

  for name in pairs(newSnap) do
    if snapshot[name] ~= newSnap[name] then
      changed[#changed + 1] = name
    end
  end

  for name in pairs(snapshot) do
    if newSnap[name] == nil then
      changed[#changed + 1] = name
    end
  end

  snapshot = newSnap

  return changed
end

function getAffectedObjects(changedItems)
  local objects = getObjectNames()
  local affected = {}

  for ____, obj in ipairs(objects) do
    for ____, item in ipairs(changedItems) do
      if matchesObject(item, obj) then
        affected[#affected + 1] = obj
        break
      end
    end
  end

  return affected
end

local enabled = false
local debounceSeconds = 5

snapshot = {}

local debounceTimer = nil
local pendingQueue = {}

--- Callback set by index.ts to trigger a patch run.
local triggerPatch = nil

--- Callback set by index.ts to check if a patch is in progress.
local checkBusy = nil

--- Callback set by index.ts to push status messages.
local pushMsg = nil

selfName = ""

--- Cancels any running debounce timer.
local function cancelDebounce()
  if debounceTimer then
    LLTimers:off(debounceTimer)
    debounceTimer = nil
  end
end

--- Wires the autoupdate module to the patcher's state. Must be called once
-- during initialization, before any other function.
local function setup(____self, trigger, busy, status)
  selfName = ____self
  triggerPatch = trigger
  checkBusy = busy
  pushMsg = status
end

--- Enables autoupdate and takes an initial inventory snapshot.
local function enable()
  cancelDebounce()
  enabled = true
  snapshot = takeSnapshot()
  pendingQueue = {}
end

--- Disables autoupdate and cancels any pending debounce.
local function disable()
  enabled = false
  cancelDebounce()
  pendingQueue = {}
end

local function isEnabled()
  return enabled
end

local function getDebounceSeconds()
  return debounceSeconds
end

local function setDebounceSeconds(n)
  debounceSeconds = n
end

--- Called from the `changed` event handler when `CHANGED_INVENTORY` fires.
-- Resets the debounce timer. When it fires, diffs the snapshot, matches
-- changed items to target objects, and either triggers a patch run or
-- merges into the pending queue if busy.
local function onInventoryChanged()
  if not enabled or checkBusy and checkBusy() then
    return
  end

  cancelDebounce()
  debounceTimer = LLTimers:once(debounceSeconds, function()
    debounceTimer = nil

    local changed = diffSnapshot()

    if #changed == 0 then
      return
    end

    local affected = getAffectedObjects(changed)

    if #affected == 0 then
      return
    end

    if triggerPatch and pushMsg then
      pushMsg(
        ((("Auto-update: " .. tostring(#changed)) .. " item(s) changed, patching ") .. tostring(#affected))
          .. " object(s)..."
      )
      triggerPatch(affected)
    end
  end)
end

--- Returns and clears any pending autoupdate queue. Called by index.ts
-- when a patch run completes to check for follow-up work.
local function flushPending()
  local queue = pendingQueue

  pendingQueue = {}

  return queue
end

local WHITE = vector.one

--- Shows floating text above the patcher prim.
local function setStatus(text)
  ll.SetText(text, WHITE, 1)
end

--- Hides the floating text.
local function clearStatus()
  ll.SetText("", vector.zero, 0)
end

--- Emits a particle beam toward the target object being patched.
local function startParticles(targetId)
  ll.ParticleSystem({
    PSYS_SRC_PATTERN,
    PSYS_SRC_PATTERN_ANGLE_CONE_EMPTY,
    PSYS_SRC_TARGET_KEY,
    targetId,
    PSYS_SRC_TEXTURE,
    "1d8f5508-86ae-4131-9044-dbb9d06d3385",
    PSYS_PART_START_COLOR,
    vector.create(1, 1, 1),
    PSYS_PART_START_ALPHA,
    1,
    PSYS_PART_START_SCALE,
    vector.create(0.125, 0.125, 0),
    PSYS_SRC_MAX_AGE,
    0,
    PSYS_PART_MAX_AGE,
    3.1,
    PSYS_SRC_BURST_RATE,
    3.1,
    PSYS_SRC_BURST_PART_COUNT,
    1,
    PSYS_PART_FLAGS,

    bit32.bor(bit32.bor(PSYS_PART_EMISSIVE_MASK, PSYS_PART_FOLLOW_SRC_MASK), PSYS_PART_TARGET_LINEAR_MASK),
  })
end

--- Stops the particle beam.
local function stopParticles()
  ll.ParticleSystem({})
end

