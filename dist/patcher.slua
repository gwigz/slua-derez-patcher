end
--- Decodes a single URL-encoded value (+ -> space, %XX -> char).
-- Collects parts into an array and joins once to avoid O(N²) string concat.
local function urlDecode(self, encoded)
    local result = (string.gsub(encoded, "+", " "))
    local parts = {}
    local len = #result
    local i = 1
    while i <= len do
        local ch = string.sub(result, i, i)
        if ch == "%" and i + 2 <= len then
            local hex = string.sub(result, i + 1, i + 2)
            local match = string.find(hex, "^%x%x$")
            if match then
                parts[#parts + 1] = string.char(tonumber(hex, 16))
                i = i + 3
            else
                parts[#parts + 1] = ch
                i = i + 1
            end
        else
            parts[#parts + 1] = ch
            i = i + 1
        end
    end
    return table.concat(parts, "")
end
--- Extracts the first value for a given key from a URL-encoded form body.
function ____exports.parseFormValue(self, body, key)
    for ____, pair in ipairs(string.split(body, "&")) do
        local eqIdx = (string.find(pair, "=", 1, true) or 0) - 1
        if eqIdx >= 0 and string.sub(pair, 1, eqIdx) == key then
            return urlDecode(
                nil,
                string.sub(pair, eqIdx + 1 + 1)
            )
        end
    end
    return nil
end
--- Parses URL-encoded form body to extract selected item names.
-- Body format: "item=ObjName/script.slua&item=ObjName/other.slua"
