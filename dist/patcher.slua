["patcher.ui"] = function(...) 
local ____exports = {}
local ____inventory = require("patcher.inventory")
local getObjectNames = ____inventory.getObjectNames
local getItemsForObject = ____inventory.getItemsForObject
local patternMatches = ____inventory.patternMatches
local targetItemName = ____inventory.targetItemName
local inventoryTypeLabel = ____inventory.inventoryTypeLabel
local EMPTY_STATE = "<div class=\"c\">No patchable objects found in inventory.</div>"
local STATUS_DONE = "<b>Done</b>"
local POLL_TRIGGER = "<div hx-get=\"poll\" hx-trigger=\"load\" hx-target=\"#c\"></div>"
____exports.NO_ITEMS_SELECTED = "<b>No items selected</b>"
--- Escapes HTML special characters to prevent XSS.
local function escapeHtml(self, s)
    return ll.ReplaceSubString(
        ll.ReplaceSubString(
            ll.ReplaceSubString(
                ll.ReplaceSubString(s, "&", "&amp;", 0),
                "<",
                "&lt;",
                0
            ),
            ">",
            "&gt;",
            0
        ),
        "\"",
        "&quot;",
        0
    )
end
--- Builds an inventory row with a type-specific badge.
local function buildItemRow(self, fullItemName)
    local typeLabel = inventoryTypeLabel(
        nil,
        ll.GetInventoryType(fullItemName)
    )
    local escaped = escapeHtml(nil, fullItemName)
    local itemName = escapeHtml(
        nil,
        targetItemName(nil, fullItemName)
    )
    return ((((((("<label class=\"k\"><input type=\"checkbox\" name=\"item\" value=\"" .. escaped) .. "\" x-on:change=\"sync()\"/><b class=\"h n\" tooltip-top=\"") .. itemName) .. "\">") .. itemName) .. "</b><kbd secondary>") .. typeLabel) .. "</kbd></label>"
end
--- Builds the object list HTML with expandable groups and per-item checkboxes.
-- Each item checkbox has name="item" value="ObjectName/item-name".
function ____exports.buildObjectList(self, selfName)
    local objects = getObjectNames(nil)
    local html = ""
    for ____, obj in ipairs(objects) do
        local ____getItemsForObject_result_0 = getItemsForObject(nil, selfName, obj)
        local scripts = ____getItemsForObject_result_0.scripts
        local items = ____getItemsForObject_result_0.items
        if #scripts > 0 or #items > 0 then
            local escaped = escapeHtml(nil, obj)
            local itemsHtml = ""
            for ____, script in ipairs(scripts) do
                itemsHtml = itemsHtml .. buildItemRow(nil, script)
            end
            for ____, item in ipairs(items) do
                itemsHtml = itemsHtml .. buildItemRow(nil, item)
            end
            html = html .. ((((((("<details class=\"i\"><summary><div class=\"d\"><b class=\"e\">&#9654;</b><input type=\"checkbox\" x-on:click.stop=\"" .. ("toggleObject('" .. escaped) .. "')") .. "\"/><b class=\"m n\" tooltip-top=\"") .. escaped) .. "\">") .. escaped) .. "</b></div></summary><div class=\"j\">") .. itemsHtml) .. "</div></details>"
        end
    end
    if html == "" then
        return EMPTY_STATE
    end
    return html
end
--- Builds a status fragment showing current patch progress.
-- Includes an hx-get="poll" trigger to continue long polling while busy.
function ____exports.buildStatusFragment(self, busy, index, total, log)
    local html = ""
    if busy then
        html = html .. ((((((("<b>Patching " .. tostring(index)) .. "/") .. tostring(total)) .. "</b><progress value=\"") .. tostring(index)) .. "\" max=\"") .. tostring(total)) .. "\"></progress>"
    elseif total > 0 then
        html = html .. ((("<b>Done</b><progress value=\"" .. tostring(total)) .. "\" max=\"") .. tostring(total)) .. "\"></progress>"
    else
        html = html .. STATUS_DONE
    end
    if #log > 0 then
        local logHtml = ""
        for ____, entry in ipairs(log) do
            logHtml = logHtml .. ("<p>" .. escapeHtml(nil, entry)) .. "</p>"
        end
        html = html .. ("<div class=\"g\">" .. logHtml) .. "</div>"
    end
    if busy then
        html = html .. POLL_TRIGGER
    end
