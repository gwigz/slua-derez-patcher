        .. baseUrl
      ) .. '/"/><title>'
    ) .. objectName
  )
    .. '</title><link rel="icon" href="data:image/svg+xml,&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; viewBox=&quot;0 0 100 100&quot;&gt;&lt;text y=&quot;.9em&quot; font-size=&quot;90&quot;&gt;🎯&lt;/text&gt;&lt;/svg&gt;"/><link rel="stylesheet" href="//cdn.jsdelivr.net/gh/fordus/shadcn-classless@main/dist/shadcn-classless.css"/><script src="//cdn.jsdelivr.net/npm/htmx.org@2/dist/htmx.min.js"></script><script>/*<![CDATA[*/document.addEventListener("alpine:init",()=>{Alpine.data("patcher",function(){return{items:[],allChecked:!1,toggleAll(){const e=[...this.$root.querySelectorAll("input[name=item]")],t=[...this.$root.querySelectorAll(".d input[type=checkbox]")],c=[...this.$root.querySelectorAll("details")];this.allChecked?(this.items=[],e.forEach(e=>e.checked=!1),t.forEach(e=>e.checked=!1),c.forEach(e=>e.open=!1)):(this.items=e.map(e=>(e.checked=!0,e.value)),t.forEach(e=>e.checked=!0),c.forEach(e=>e.open=!0)),this.allChecked=!this.allChecked},toggleObject(e){const t=[...this.$root.querySelectorAll(".i")].find(t=>t.querySelector(".m").textContent===e);if(!t)return;const c=[...t.querySelectorAll("input[name=item]")],o=c.every(e=>e.checked);c.forEach(e=>e.checked=!o),t.open=!0,this.sync()},updateObjBoxes(){this.$root.querySelectorAll(".d input[type=checkbox]").forEach(e=>{const t=[...e.closest(".i").querySelectorAll("input[name=item]")],c=t.filter(e=>e.checked).length,o=t.length;e.checked=o>0&&c===o,e.indeterminate=c>0&&c<o})},sync(){this.items=[...this.$root.querySelectorAll("input[name=item]:checked")].map(e=>e.value);const e=this.$root.querySelectorAll("input[name=item]");this.allChecked=this.items.length>0&&this.items.length===e.length,this.updateObjBoxes()}}})})/*]]>*/</script><script src="//cdn.jsdelivr.net/npm/lucide@0.460/dist/umd/lucide.min.js"></script><style>b{font-weight:inherit}body{max-width:580px;padding:1.5rem 1rem}input[type=checkbox]{margin:0;flex-shrink:0}h2{margin:0 0 1rem}.k,.d,.f,.o{display:flex;align-items:center;gap:.5rem}.f label,.o labe