hx-get="app" hx-trigger="load"><article aria-busy="spinner" style="text-align:center"></article></main><script>/*<![CDATA[*/document.addEventListener("htmx:load",e=>{lucide.createIcons(),window.Alpine&&Alpine.initTree(e.target)})/*]]>*/</script><script defer="" src="//cdn.jsdelivr.net/npm/alpinejs@3/dist/cdn.min.js"></script></body></html>'
