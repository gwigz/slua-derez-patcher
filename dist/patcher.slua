end
LLEvents:on(
    "http_request",
    function(requestId, method, body)
        if method == URL_REQUEST_GRANTED then
            httpUrl = body
            ll.OwnerSay("Web UI: " .. httpUrl)
            return
        end
        if method == URL_REQUEST_DENIED then
            ll.OwnerSay("Failed to get HTTP URL: " .. body)
            return
        end
        local url = ll.GetHTTPHeader(requestId, "x-path-info")
        if method == "GET" then
            if url == "" or url == "/" then
                respondHtml(
                    nil,
                    requestId,
                    pageShell(
                        nil,
                        httpUrl,
                        ll.GetObjectName()
                    )
                )
            elseif url == "/app" then
                respondHtml(
                    nil,
                    requestId,
                    appFragment(
                        nil,
                        ll.GetObjectName()
                    )
                )
            elseif url == "/objects" then
                respondHtml(
                    nil,
                    requestId,
                    buildObjectList(nil, SELF_NAME)
                )
            elseif url == "/poll" then
                if pollRequestId ~= "" then
                    respondHtml(
                        nil,
                        pollRequestId,
                        statusFragment(nil)
                    )
                end
                pollRequestId = requestId
                if pollTimer then
                    LLTimers:off(pollTimer)
                end
                pollTimer = LLTimers:once(
                    20,
                    function()
                        pollTimer = nil
                        respondPoll(nil)
                    end
                )
            elseif url == "/autoupdate" then
                respondHtml(
                    nil,
                    requestId,
                    buildAutoUpdateControls(
                        nil,
                        isAutoUpdateEnabled(nil),
                        getDebounceSeconds(nil)
                    )
                )
            else
                ll.HTTPResponse(requestId, 404, "Not found")
            end
        elseif method == "POST" then
            if url == "/patch" then
                if busy then
                    respondHtml(
                        nil,
                        requestId,
                        statusFragment(nil)
                    )
                    return
                end
                local ____parseFormItems_result_2 = parseFormItems(nil, body)
                local queue = ____parseFormItems_result_2.queue
                local filter = ____parseFormItems_result_2.filter
                if #queue == 0 then
                    respondHtml(nil, requestId, NO_ITEMS_SELECTED)
                    return
                end
                startPatching(nil, queue, filter)
                respondHtml(
                    nil,
                    requestId,
                    statusFragment(nil)
                )
            elseif url == "/patch-all" then
                if busy then
                    respondHtml(
                        nil,
                        requestId,
                        statusFragment(nil)
                    )
                    return
                end
                local queue = {}
                for ____, obj in ipairs(getObjectNames(nil)) do
                    local ____getItemsForObject_result_3 = getItemsForObject(nil, SELF_NAME, obj)
                    local scripts = ____getItemsForObject_result_3.scripts
                    local items = ____getItemsForObject_result_3.items
                    if #scripts > 0 or #items > 0 then
                        queue[#queue + 1] = obj
                    end
                end
                if #queue > 0 then
                    startPatching(nil, queue)
                end
                respondHtml(
                    nil,
                    requestId,
                    statusFragment(nil)
                )
            elseif url == "/autoupdate" then
                if parseFormValue(nil, body, "enabled") == "on" then
                    enableAutoUpdate(nil)
                else
                    disableAutoUpdate(nil)
                end
                respondHtml(
                    nil,
                    requestId,
                    buildAutoUpdateControls(
                        nil,
                        isAutoUpdateEnabled(nil),
                        getDebounceSeconds(nil)
                    )
                )
            elseif url == "/autoupdate-debounce" then
                local seconds = tonumber(parseFormValue(nil, body, "debounce") or "")
                if seconds ~= nil and seconds >= 1 and seconds <= 60 then
                    setDebounceSeconds(nil, seconds)
                end
                respondHtml(
                    nil,
                    requestId,
                    buildAutoUpdateControls(
                        nil,
                        isAutoUpdateEnabled(nil),
                        getDebounceSeconds(nil)
                    )
                )
            else
                ll.HTTPResponse(requestId, 404, "Not found")
            end
        else
            ll.HTTPResponse(requestId, 405, "Method not allowed")
        end
    end
)
LLEvents:on(
    "listen",
    function(channel, _name, id, message)
        if channel == CMD_CHANNEL then
            if id ~= ll.GetOwner() then
                return
            end
            if message == "url" then
                if httpUrl ~= "" then
                    ll.OwnerSay(httpUrl)
                else
                    ll.OwnerSay("HTTP URL not yet available.")
                end
            elseif message == "auto" or string.find(message, "auto ", 1, true) == 1 then
                local arg = ll.StringTrim(
                    string.sub(message, 6),
                    STRING_TRIM
                )
                if arg ~= "" then
                    local seconds = tonumber(arg)
                    if seconds ~= nil and seconds >= 1 then
                        setDebounceSeconds(nil, seconds)
                        enableAutoUpdate(nil)
                        ll.OwnerSay(("Auto-update enabled (" .. tostring(seconds)) .. "s debounce).")
                    else
                        ll.OwnerSay("Usage: /7 auto [seconds]")
                    end
                elseif isAutoUpdateEnabled(nil) then
                    disableAutoUpdate(nil)
                    ll.OwnerSay("Auto-update disabled.")
                else
                    enableAutoUpdate(nil)
                    ll.OwnerSay(("Auto-update enabled (" .. tostring(getDebounceSeconds(nil))) .. "s debounce).")
                end
            end
        elseif channel == COMM_CHANNEL and busy then
            if message == "pinned" and id == currentObjectId then
                for ____, item in ipairs(pendingItems) do
                    ll.GiveInventory(currentObjectId, item)
                    completedItems = completedItems + 1
                end
                startParticles(nil, currentObjectId)
                pendingScriptIdx = 0
                loadNextScript(nil)
            elseif message == "ready" and id == currentObjectId then
                if timeoutTimer then
                    LLTimers:off(timeoutTimer)
                    timeoutTimer = nil
                end
                if scriptLoadTimer then
                    LLTimers:off(scriptLoadTimer)
                    scriptLoadTimer = nil
                end
                logStatus(nil, currentObjectName .. " patched successfully.")
                ll.DerezObject(currentObjectId, DEREZ_TO_INVENTORY)
                patchNext(nil)
            end
        end
    end
)
