local function appFragment(objectName)
  return ("<h2>" .. objectName)
    .. '</h2><hr/><form x-data="patcher"><div class="o"><label><input type="checkbox" x-bind:checked="allChecked" x-on:click="toggleAll()"/> All</label><b style="flex:1"></b><button type="submit" hx-post="patch" hx-target="#c" x-show="items.length" x-bind:disabled="items.length === 0"><i data-lucide="play"></i> Patch</button><button type="button" hx-post="patch-all" hx-target="#c"><i data-lucide="layers"></i> Patch All</button><button type="button" class="secondary" hx-get="objects" hx-target="#b"><i data-lucide="refresh-cw"></i></button></div><div id="b" hx-get="objects" hx-trigger="load" x-on:change="sync()" x-on:htmx:after-swap.camel="sync()"><article aria-busy="spinner" style="text-align:center"></article></div></form><div id="a" hx-get="autoupdate" hx-trigger="load"></div><article class="p"><div class="b">Status</div><div id="c" class="f">Ready</div></article>'
end

local EMPTY_STATE = '<div class="c">No patchable objects found in inventory.</div>'

local POLL_TRIGGER = '<div hx-get="poll" hx-trigger="load" hx-target="#c"></div>'
local NO_ITEMS_SELECTED = "<b>No items selected</b>"

--- Escapes HTML special characters to prevent XSS.
local function escapeHtml(s)
  return ll.ReplaceSubString(

    ll.ReplaceSubString(ll.ReplaceSubString(ll.ReplaceSubString(s, "&", "&amp;", 0), "<", "&lt;", 0), ">", "&gt;", 0),
    '"',
    "&quot;",
    0
  )
end

--- Builds an inventory row with a type-specific badge.
local function buildItemRow(fullItemName)
  local typeLabel = inventoryTypeLabel(ll.GetInventoryType(fullItemName))
  local escaped = escapeHtml(fullItemName)
  local itemName = escapeHtml(targetItemName(fullItemName))

  return (
    (
      (
        (
          (
            (
              ('<label class="k"><input type="checkbox" name="item" value="' .. escaped)
              .. '" x-on:change="sync()"/><b class="h n" tooltip-top="'
            ) .. itemName
          ) .. '">'
        ) .. itemName
      ) .. "</b><kbd secondary>"
    ) .. typeLabel
  ) .. "</kbd></label>"
end

--- Builds the object list HTML with expandable groups and per-item checkboxes.
-- Each item checkbox has name="item" value="ObjectName/item-name".
local function buildObjectList(selfName)
  local objects = getObjectNames()
  local html = ""

  for ____, obj in ipairs(objects) do
    local ____getItemsForObject_result_0 = getItemsForObject(selfName, obj)
    local scripts = ____getItemsForObject_result_0.scripts
    local items = ____getItemsForObject_result_0.items

    if #scripts > 0 or #items > 0 then
      local escaped = escapeHtml(obj)
      local itemsHtml = ""

      for ____, script in ipairs(scripts) do
        itemsHtml = itemsHtml .. buildItemRow(script)
      end

      for ____, item in ipairs(items) do
        itemsHtml = itemsHtml .. buildItemRow(item)
      end

      html = html
        .. ((((((('<details class="i"><summary><div class="d"><b class="e">&#9654;</b><input type="checkbox" x-on:click.stop="' .. ("toggleObject('" .. escaped) .. "')") .. '"/><b class="m n" tooltip-top="') .. escaped) .. '">') .. escaped) .. '</b></div></summary><div class="j">') .. itemsHtml)
        .. "</div></details>"
    end
  end

  if html == "" then
    return EMPTY_STATE
  end

  return html
end

--- Builds a status fragment showing current patch progress.
-- Includes an hx-get="poll" trigger to continue long polling while busy.
local function buildStatusFragment(busy, index, total, log)
  local html = ""

  if busy then
    html = html
      .. ((((((("<b>Patching " .. tostring(index)) .. "/") .. tostring(total)) .. '</b><progress value="') .. tostring(
        index
      )) .. '" max="') .. tostring(total))
      .. '"></progress>'
  elseif total > 0 then
    html = html
      .. ((('<b>Done</b><progress value="' .. tostring(total)) .. '" max="') .. tostring(total))
      .. '"></progress>'
  else
    html = html .. "<b>Done</b>"
  end

  if #log > 0 then
    local logHtml = ""

    for ____, entry in ipairs(log) do
      logHtml = logHtml .. ("<p>" .. escapeHtml(entry)) .. "</p>"
    end

    html = html .. ('<div class="g">' .. logHtml) .. "</div>"
  end

  if busy then
    html = html .. POLL_TRIGGER
  end

  return html
end

--- Decodes a single URL-encoded value (+ -> space, %XX -> char).
-- Collects parts into an array and joins once to avoid O(N²) string concat.
local function urlDecode(encoded)
  local result = (string.gsub(encoded, "+", " "))
  local parts = {}
  local len = #result
  local i = 1

  while i <= len do
    local ch = string.sub(result, i, i)

    if ch == "%" and i + 2 <= len then
      local hex = string.sub(result, i + 1, i + 2)
      local match = string.find(hex, "^%x%x$")

      if match then
        parts[#parts + 1] = string.char(tonumber(hex, 16))
        i = i + 3
      else
        parts[#parts + 1] = ch
        i = i + 1
      end
    else
      parts[#parts + 1] = ch
      i = i + 1
    end
  end

  return table.concat(parts, "")
end

--- Extracts the first value for a given key from a URL-encoded form body.
local function parseFormValue(body, key)
  for ____, pair in ipairs(string.split(body, "&")) do
    local eqIdx = (string.find(pair, "=", 1, true) or 0) - 1

    if eqIdx >= 0 and string.sub(pair, 1, eqIdx) == key then
      return urlDecode(string.sub(pair, eqIdx + 1 + 1))
    end
  end

  return nil
end

--- Parses URL-encoded form body to extract selected item names.
-- Body format: "item=ObjName/script.slua&item=ObjName/other.slua"
--
-- Returns an ordered queue of unique object names and a filter map of
-- object name -> selected full item names.
local function parseFormItems(body)
  local filter = {}
  local queue = {}
  local objects = getObjectNames()

  for ____, pair in ipairs(string.split(body, "&")) do
    local eqIdx = (string.find(pair, "=", 1, true) or 0) - 1

    if eqIdx < 0 then
    else
      local key = string.sub(pair, 1, eqIdx)

      if key == "item" then
        local fullName = urlDecode(string.sub(pair, eqIdx + 1 + 1))
        local slashIdx = (string.find(fullName, "/", 1, true) or 0) - 1

        if slashIdx >= 0 then
          local prefix = string.sub(fullName, 1, slashIdx)

          if string.find(prefix, "{", 1, true) == 1 and (string.find(prefix, "}", 1, true) or 0) - 1 == #prefix - 1 then
            local pattern = string.sub(prefix, 2, #prefix - 1)

            for ____, obj in ipairs(objects) do
              if patternMatches(obj, pattern) then
                if filter[obj] == nil then
                  filter[obj] = {}
                  queue[#queue + 1] = obj
                end

                local ____filter_obj_1 = filter[obj]

                ____filter_obj_1[#____filter_obj_1 + 1] = fullName
              end
            end
          else
            if filter[prefix] == nil then
              filter[prefix] = {}
              queue[#queue + 1] = prefix
            end

            local ____filter_prefix_2 = filter[prefix]

            ____filter_prefix_2[#____filter_prefix_2 + 1] = fullName
          end
        end
      end
    end
  end

  return { queue = queue, filter = filter }
end

--- Builds the autoupdate controls reflecting current server state.
-- Returned for GET /autoupdate and POST /autoupdate.
local function buildAutoUpdateControls(enabled, debounce)
  if enabled then
    return (
      '<article class="p"><div class="b">Settings</div><div class="f"><label><input type="checkbox" name="enabled" checked="" hx-post="autoupdate" hx-target="#a"/> Auto-update</label><label class="a">Delay <input type="number" name="debounce" value="'
      .. tostring(debounce)
    )
      .. '" min="1" max="60" hx-post="autoupdate-debounce" hx-target="#a" hx-trigger="change delay:500ms"/> s</label></div></article>'
  end

  return (
    '<article class="p"><div class="b">Settings</div><div class="f"><label><input type="checkbox" name="enabled" hx-post="autoupdate" hx-target="#a"/> Auto-update</label><label class="a">Delay <input type="number" name="debounce" value="'
    .. tostring(debounce)
  )
    .. '" min="1" max="60" hx-post="autoupdate-debounce" hx-target="#a" hx-trigger="change delay:500ms"/> s</label></div></article>'
end

-- Lua Library inline imports
local function __TS__ArrayFilter(self, callbackfn, thisArg)
  local result = {}
  local len = 0

  for i = 1, #self do
    if callbackfn(thisArg, self[i], i - 1, self) then
      len = len + 1
      result[len] = self[i]
    end
  end

  return result
end

-- End of Lua Library inline imports
local logStatus, pushStatus, statusFragment, respondPoll, patchNext, startPatching, respondHtml, SELF_NAME, currentObjectId, currentObjectName, patchQueue, patchItemFilter, queueIndex, totalItems, completedItems, busy, timeoutTimer, pendingScripts, pendingItems, scriptLoadTimer, pollRequestId, pollTimer, statusLog
local setupAutoUpdate = setup
local isAutoUpdateEnabled = isEnabled
local enableAutoUpdate = enable
local disableAutoUpdate = disable

function logStatus(message)
  ll.OwnerSay(message)
  statusLog[#statusLog + 1] = message

  if #statusLog > 20 then
    table.remove(statusLog, 1)
  end
end

function pushStatus(message)
  logStatus(message)

  if pollRequestId ~= "" then
    respondPoll()
  end
end

function statusFragment()
  return buildStatusFragment(busy, completedItems, totalItems, statusLog)
end

function respondPoll()
  if pollRequestId == "" then
    return
  end

  respondHtml(pollRequestId, statusFragment())
  pollRequestId = ""

  if pollTimer then
    LLTimers:off(pollTimer)
    pollTimer = nil
  end
end

function patchNext()
  if queueIndex >= #patchQueue then
    busy = false
    patchQueue = {}
    patchItemFilter = {}
    queueIndex = 0

    local pending = flushPending()

    if #pending > 0 then
      pushStatus(("Auto-update: patching " .. tostring(#pending)) .. " queued object(s)...")
      startPatching(pending, nil, false)

      return
    end

    clearStatus()
    pushStatus("All objects patched.")

    return
  end

  currentObjectName = patchQueue[queueIndex + 1]
  queueIndex = queueIndex + 1

  local ____getItemsForObject_result_0 = getItemsForObject(SELF_NAME, currentObjectName)
  local scripts = ____getItemsForObject_result_0.scripts
  local items = ____getItemsForObject_result_0.items
  local filter = patchItemFilter[currentObjectName]

  if filter and #filter > 0 then
    pendingScripts = __TS__ArrayFilter(scripts, function(____, s)
      return table.find(filter, s) ~= nil
    end)
    pendingItems = __TS__ArrayFilter(items, function(____, it)
      return table.find(filter, it) ~= nil
    end)
  else
    pendingScripts = scripts
    pendingItems = items
  end

  if #pendingScripts == 0 and #pendingItems == 0 then
    pushStatus(("No items found for " .. currentObjectName) .. ", skipping.")
    patchNext()

    return
  end

  setStatus(
    (
      (
        (
          (
            (
              (
                (((currentObjectName .. "\n") .. tostring(#pendingScripts)) .. " script(s), ") .. tostring(
                  #pendingItems
                )
              ) .. " item(s)"
            ) .. "\n["
          ) .. tostring(completedItems)
        ) .. "/"
      ) .. tostring(totalItems)
    ) .. "]"
  )
  pushStatus(
    ((((("Rezzing " .. currentObjectName) .. "... [") .. tostring(completedItems)) .. "/") .. tostring(totalItems))
      .. "]"
  )
  currentObjectId = ll.RezObjectWithParams(currentObjectName, {
    REZ_POS,
    vector.create(0, 0, 1),
    1,
    0,
    REZ_PARAM,
    PIN,
  })

  local timeoutSeconds = #pendingScripts * 3.5 + 10

  timeoutTimer = LLTimers:once(timeoutSeconds, function()
    stopParticles()

    if scriptLoadTimer then
      LLTimers:off(scriptLoadTimer)
      scriptLoadTimer = nil
    end

    pushStatus(("Timeout waiting for " .. currentObjectName) .. ", derezing.")
    ll.DerezObject(currentObjectId, DEREZ_DIE)
    timeoutTimer = nil
    patchNext()
  end)
end

function startPatching(queue, itemFilter, resetLog)
  if resetLog == nil then
    resetLog = true
  end

  patchQueue = queue
  patchItemFilter = itemFilter or {}
  queueIndex = 0
  completedItems = 0
  busy = true
  totalItems = 0

  for ____, obj in ipairs(queue) do
    local ____getItemsForObject_result_1 = getItemsForObject(SELF_NAME, obj)
    local scripts = ____getItemsForObject_result_1.scripts
    local items = ____getItemsForObject_result_1.items
    local filter = patchItemFilter[obj]

    if filter and #filter > 0 then
      totalItems = totalItems
        + #__TS__ArrayFilter(scripts, function(____, s)
          return table.find(filter, s) ~= nil
        end)
      totalItems = totalItems
        + #__TS__ArrayFilter(items, function(____, it)
          return table.find(filter, it) ~= nil
        end)
    else
      totalItems = totalItems + (#scripts + #items)
    end
  end

  if resetLog then
    statusLog = {}
  end

  pushStatus(((("Patching " .. tostring(totalItems)) .. " item(s) across ") .. tostring(#queue)) .. " object(s)...")
  patchNext()
end

function respondHtml(requestId, body)
  ll.SetContentType(requestId, CONTENT_TYPE_XHTML)
  ll.HTTPResponse(requestId, 200, body)
end

SELF_NAME = ll.GetScriptName()
currentObjectName = ""
patchQueue = {}
patchItemFilter = {}
queueIndex = 0
totalItems = 0
completedItems = 0
busy = false
timeoutTimer = nil
pendingScripts = {}
pendingItems = {}

--- Index into pendingScripts for timer-based sequential loading.
local pendingScriptIdx = 0

scriptLoadTimer = nil

--- The HTTP-in URL assigned by the simulator.
local httpUrl = ""

pollRequestId = ""
pollTimer = nil
statusLog = {}

--- Loads pending scripts one at a time using a timer chain.
-- Yields to the event loop between loads so the browser can re-establish
-- its long poll and receive real-time progress updates.
local function loadNextScript()
  if pendingScriptIdx >= #pendingScripts then
    stopParticles()
    ll.RegionSayTo(currentObjectId, COMM_CHANNEL, "done")

    return
  end

  local script = pendingScripts[pendingScriptIdx + 1]
  local name = targetItemName(script)

  setStatus(
    (
      (((((currentObjectName .. "\nLoading ") .. name) .. "\n[") .. tostring(completedItems)) .. "/")
      .. tostring(totalItems)
    ) .. "]"
  )
  pushStatus((("Loading " .. name) .. " into ") .. currentObjectName)

  ll.RemoteLoadScriptPin(currentObjectId, script, PIN, 1, 0)
  completedItems = completedItems + 1
  pendingScriptIdx = pendingScriptIdx + 1
  scriptLoadTimer = LLTimers:once(0.5, function()
    scriptLoadTimer = nil
    loadNextScript()
  end)
end

--- Releases the current HTTP-in URL and requests a new one.
local function refreshUrl()
  pollRequestId = ""

  if pollTimer then
    LLTimers:off(pollTimer)
    pollTimer = nil
  end

  if httpUrl ~= "" then
    ll.ReleaseURL(httpUrl)
    httpUrl = ""
  end

  ll.RequestURL()
end

LLEvents:on("http_request", function(requestId, method, body)
  if method == URL_REQUEST_GRANTED then
    httpUrl = body
    ll.OwnerSay("Web UI: " .. httpUrl)

    return
  end

  if method == URL_REQUEST_DENIED then
    ll.OwnerSay("Failed to get HTTP URL: " .. body)

    return
  end

  local url = ll.GetHTTPHeader(requestId, "x-path-info")

  if method == "GET" then
    if url == "" or url == "/" then
      respondHtml(requestId, pageShell(httpUrl, ll.GetObjectName()))
    elseif url == "/app" then
      respondHtml(requestId, appFragment(ll.GetObjectName()))
    elseif url == "/objects" then
      respondHtml(requestId, buildObjectList(SELF_NAME))
    elseif url == "/poll" then
      if pollRequestId ~= "" then
        respondHtml(pollRequestId, statusFragment())
      end

      pollRequestId = requestId

      if pollTimer then
        LLTimers:off(pollTimer)
      end

      pollTimer = LLTimers:once(20, function()
        pollTimer = nil
        respondPoll()
      end)
    elseif url == "/autoupdate" then
      respondHtml(requestId, buildAutoUpdateControls(isAutoUpdateEnabled(), getDebounceSeconds()))
    else
      ll.HTTPResponse(requestId, 404, "Not found")
    end
  elseif method == "POST" then
    if url == "/patch" then
      if busy then
        respondHtml(requestId, statusFragment())

        return
      end

      local ____parseFormItems_result_2 = parseFormItems(body)
      local queue = ____parseFormItems_result_2.queue
      local filter = ____parseFormItems_result_2.filter

      if #queue == 0 then
        respondHtml(requestId, NO_ITEMS_SELECTED)

        return
      end

      startPatching(queue, filter)

      respondHtml(requestId, statusFragment())
    elseif url == "/patch-all" then
      if busy then
        respondHtml(requestId, statusFragment())

        return
      end

      local queue = {}

      for ____, obj in ipairs(getObjectNames()) do
        local ____getItemsForObject_result_3 = getItemsForObject(SELF_NAME, obj)
        local scripts = ____getItemsForObject_result_3.scripts
        local items = ____getItemsForObject_result_3.items

        if #scripts > 0 or #items > 0 then
          queue[#queue + 1] = obj
        end
      end

      if #queue > 0 then
        startPatching(queue)
      end

      respondHtml(requestId, statusFragment())
    elseif url == "/autoupdate" then
      if parseFormValue(body, "enabled") == "on" then
        enableAutoUpdate()
      else
        disableAutoUpdate()
      end

      respondHtml(requestId, buildAutoUpdateControls(isAutoUpdateEnabled(), getDebounceSeconds()))
    elseif url == "/autoupdate-debounce" then
      local seconds = tonumber(parseFormValue(body, "debounce") or "")

      if seconds ~= nil and seconds >= 1 and seconds <= 60 then
        setDebounceSeconds(seconds)
      end

      respondHtml(requestId, buildAutoUpdateControls(isAutoUpdateEnabled(), getDebounceSeconds()))
    else
      ll.HTTPResponse(requestId, 404, "Not found")
    end
  else
    ll.HTTPResponse(requestId, 405, "Method not allowed")
  end
end)

LLEvents:on("listen", function(channel, _name, id, message)
  if channel == CMD_CHANNEL then
    if id ~= ll.GetOwner() then
      return
    end

    if message == "url" then
      if httpUrl ~= "" then
        ll.OwnerSay(httpUrl)
      else
        ll.OwnerSay("HTTP URL not yet available.")
      end
    elseif message == "auto" or string.find(message, "auto ", 1, true) == 1 then
      local arg = ll.StringTrim(string.sub(message, 6), STRING_TRIM)

      if arg ~= "" then
        local seconds = tonumber(arg)

        if seconds ~= nil and seconds >= 1 then
          setDebounceSeconds(seconds)
          enableAutoUpdate()
          ll.OwnerSay(("Auto-update enabled (" .. tostring(seconds)) .. "s debounce).")
        else
          ll.OwnerSay("Usage: /7 auto [seconds]")
        end
      elseif isAutoUpdateEnabled() then
        disableAutoUpdate()
        ll.OwnerSay("Auto-update disabled.")
      else
        enableAutoUpdate()
        ll.OwnerSay(("Auto-update enabled (" .. tostring(getDebounceSeconds())) .. "s debounce).")
      end
    end
  elseif channel == COMM_CHANNEL and busy then
    if message == "pinned" and id == currentObjectId then
      for ____, item in ipairs(pendingItems) do
        ll.GiveInventory(currentObjectId, item)
        completedItems = completedItems + 1
      end

      startParticles(currentObjectId)
      pendingScriptIdx = 0
      loadNextScript()
    elseif message == "ready" and id == currentObjectId then
      if timeoutTimer then
        LLTimers:off(timeoutTimer)
        timeoutTimer = nil
      end

      if scriptLoadTimer then
        LLTimers:off(scriptLoadTimer)
        scriptLoadTimer = nil
      end

      logStatus(currentObjectName .. " patched successfully.")
      ll.DerezObject(currentObjectId, DEREZ_TO_INVENTORY)
      patchNext()
    end
  end
end)

LLEvents:on("on_rez", function()
  refreshUrl()
end)

LLEvents:on("attach", function()
  refreshUrl()
end)

LLEvents:on("changed", function(change)
  if bit32.btest(change, CHANGED_INVENTORY) then
    onInventoryChanged()
  end

  if bit32.btest(change, bit32.bor(CHANGED_REGION, CHANGED_REGION_START)) then
    refreshUrl()
  end
end)

ll.Listen(CMD_CHANNEL, "", NULL_KEY, "")
ll.Listen(COMM_CHANNEL, "", NULL_KEY, "")
ll.RequestURL()

setupAutoUpdate(SELF_NAME, startPatching, function()
  return busy
end, pushStatus)

do
  local used = ll.GetUsedMemory()
  local limit = ll.GetMemoryLimit()

  ll.OwnerSay(
    (
      (((("Memory: " .. tostring(used // 1024)) .. "KB / ") .. tostring(limit // 1024)) .. "KB (")
      .. tostring(math.floor(used / limit * 100))
    ) .. "%)"
  )
end
