{
  "$schema": "https://raw.githubusercontent.com/TypeScriptToLua/TypeScriptToLua/master/tsconfig-schema.json",
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/bootstrap.ts"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["@typescript-to-lua/language-extensions", "@gwigz/slua-types"],
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment"
  },
  "tstl": {
    "extension": "slua",
    "luaTarget": "Luau",
    "luaLibImport": "inline",
    "noImplicitSelf": true,
    "luaPlugins": [{ "name": "@gwigz/slua-tstl-plugin" }, { "name": "tstl-const-propagation" }]
  }
}
